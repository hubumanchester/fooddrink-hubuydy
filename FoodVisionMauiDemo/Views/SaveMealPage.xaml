<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewModels="clr-namespace:FoodVisionMauiDemo.ViewModels"
             x:Class="FoodVisionMauiDemo.Views.SaveMealPage"
             x:DataType="viewModels:SaveMealViewModel"
             Title="Save Meal">
    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="16">
            <Label Text="{Binding FoodName}"
                   FontSize="28"
                   FontAttributes="Bold" />

            <Label Text="{Binding StatusMessage}"
                   FontSize="16"
                   TextColor="Gray" />

            <Frame BorderColor="#E5E7EB"
                   CornerRadius="8"
                   Padding="4"
                   HeightRequest="180"
                   WidthRequest="180"
                   HorizontalOptions="Center"
                   IsVisible="{Binding HasImage}">
                <Image Source="{Binding ImageSource}"
                       Aspect="AspectFit" />
            </Frame>

            <Frame BorderColor="#E5E7EB" CornerRadius="8" Padding="14">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Risk Tags"
                           FontSize="18"
                           FontAttributes="Bold" />
                    <CollectionView ItemsSource="{Binding Tags}">
                        <CollectionView.ItemsLayout>
                            <LinearItemsLayout Orientation="Horizontal" ItemSpacing="8" />
                        </CollectionView.ItemsLayout>
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="{x:Null}">
                                <Frame BorderColor="#BFDBFE"
                                       BackgroundColor="#EFF6FF"
                                       CornerRadius="8"
                                       Padding="10,6">
                                    <Label Text="{Binding .}"
                                           FontSize="14"
                                           TextColor="#1D4ED8" />
                                </Frame>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </Frame>

            <Frame BorderColor="#E5E7EB" CornerRadius="8" Padding="14">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Possible Allergens"
                           FontSize="18"
                           FontAttributes="Bold" />
                    <CollectionView ItemsSource="{Binding Allergens}"
                                    IsVisible="{Binding HasAllergens}">
                        <CollectionView.ItemsLayout>
                            <LinearItemsLayout Orientation="Horizontal" ItemSpacing="8" />
                        </CollectionView.ItemsLayout>
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="{x:Null}">
                                <Frame BorderColor="#FECACA"
                                       BackgroundColor="#FEF2F2"
                                       CornerRadius="8"
                                       Padding="10,6">
                                    <Label Text="{Binding .}"
                                           FontSize="14"
                                           TextColor="#991B1B" />
                                </Frame>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                    <Label Text="No common allergens are listed for this item."
                           FontSize="14"
                           TextColor="Gray"
                           IsVisible="{Binding HasNoAllergens}" />
                </VerticalStackLayout>
            </Frame>

            <Frame BorderColor="#E5E7EB" CornerRadius="8" Padding="14">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Better Alternatives"
                           FontSize="18"
                           FontAttributes="Bold" />
                    <CollectionView ItemsSource="{Binding Alternatives}">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="{x:Null}">
                                <Label Text="{Binding .}"
                                       FontSize="15"
                                       Margin="0,3" />
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </Frame>

            <Frame BorderColor="#E5E7EB" CornerRadius="8" Padding="14">
                <VerticalStackLayout Spacing="12">
                    <Label Text="Meal Details"
                           FontSize="18"
                           FontAttributes="Bold" />
                    <Picker Title="Meal type"
                            ItemsSource="{Binding MealTypes}"
                            SelectedItem="{Binding SelectedMealType}" />
                    <Picker Title="Portion"
                            ItemsSource="{Binding PortionOptions}"
                            SelectedItem="{Binding SelectedPortion}" />
                    <Editor Placeholder="Notes"
                            Text="{Binding Notes}"
                            AutoSize="TextChanges"
                            HeightRequest="100" />
                    <Frame BorderColor="#E5E7EB"
                           BackgroundColor="#F9FAFB"
                           CornerRadius="8"
                           Padding="12">
                        <Label Text="{Binding VoiceNotePlaceholder}"
                               FontSize="14"
                               TextColor="Gray" />
                    </Frame>
                </VerticalStackLayout>
            </Frame>

            <ActivityIndicator IsVisible="{Binding IsBusy}"
                               IsRunning="{Binding IsBusy}"
                               Color="#2563EB" />

            <Button Text="Save Meal"
                    Command="{Binding SaveMealCommand}"
                    BackgroundColor="#16A34A"
                    TextColor="White" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>

<?xml version = "1.0" encoding = "UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:FoodVisionMauiDemo"
             x:Class="FoodVisionMauiDemo.App">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Colors.xaml" />
                <ResourceDictionary Source="Resources/Styles/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <x:Double x:Key="TitleFontSize">32</x:Double>
            <x:Double x:Key="SectionFontSize">22</x:Double>
            <x:Double x:Key="BodyFontSize">16</x:Double>
            <x:Double x:Key="SmallFontSize">13</x:Double>
            <x:Double x:Key="ButtonFontSize">15.5</x:Double>
        </ResourceDictionary>
    </Application.Resources>
</Application>

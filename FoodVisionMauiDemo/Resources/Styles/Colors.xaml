<?xml version="1.0" encoding="UTF-8" ?>
<?xaml-comp compile="true" ?>
<ResourceDictionary 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- Note: For Android please see also Platforms\Android\Resources\values\colors.xml -->

    <Color x:Key="Primary">#0D9488</Color>
    <Color x:Key="PrimaryDark">#34D399</Color>
    <Color x:Key="PrimaryDarkText">#052E2B</Color>
    <Color x:Key="Secondary">#D1FAE5</Color>
    <Color x:Key="SecondaryDarkText">#A7F3D0</Color>
    <Color x:Key="Tertiary">#10B981</Color>

    <Color x:Key="PageBackground">#F4F7F4</Color>
    <Color x:Key="PageBackgroundDark">#121816</Color>
    <Color x:Key="Surface">#FFFFFC</Color>
    <Color x:Key="SurfaceDark">#202623</Color>
    <Color x:Key="SurfaceAlt">#E8F5EF</Color>
    <Color x:Key="SurfaceAltDark">#17221E</Color>
    <Color x:Key="SurfaceMuted">#EDF2EF</Color>
    <Color x:Key="SurfaceMutedDark">#27302C</Color>
    <Color x:Key="DeepSurface">#123F3A</Color>
    <Color x:Key="DeepSurfaceDark">#0D2B28</Color>
    <Color x:Key="StrokeSoft">#DDE6E0</Color>
    <Color x:Key="StrokeSoftDark">#35413B</Color>
    <Color x:Key="TextPrimary">#111827</Color>
    <Color x:Key="TextPrimaryDark">#F9FAFB</Color>
    <Color x:Key="TextSecondary">#6B7280</Color>
    <Color x:Key="TextSecondaryDark">#9CA3AF</Color>
    <Color x:Key="Muted">#94A3B8</Color>
    <Color x:Key="MutedDark">#71717A</Color>
    <Color x:Key="Success">#0D9488</Color>
    <Color x:Key="SuccessSoft">#D1FAE5</Color>
    <Color x:Key="Warning">#F59E0B</Color>
    <Color x:Key="WarningSoft">#FEF3C7</Color>
    <Color x:Key="Danger">#EF4444</Color>
    <Color x:Key="DangerSoft">#FEE2E2</Color>
    <Color x:Key="WarmAccent">#B7791F</Color>
    <Color x:Key="WarmAccentSoft">#FFF7E6</Color>
    <Color x:Key="Info">#0369A1</Color>
    <Color x:Key="InfoSoft">#E0F2FE</Color>

    <Color x:Key="White">White</Color>
    <Color x:Key="Black">Black</Color>
    <Color x:Key="Magenta">#0F766E</Color>
    <Color x:Key="MidnightBlue">#134E4A</Color>
    <Color x:Key="OffBlack">#1f1f1f</Color>

    <Color x:Key="Gray100">#E1E1E1</Color>
    <Color x:Key="Gray200">#C8C8C8</Color>
    <Color x:Key="Gray300">#ACACAC</Color>
    <Color x:Key="Gray400">#919191</Color>
    <Color x:Key="Gray500">#6E6E6E</Color>
    <Color x:Key="Gray600">#404040</Color>
    <Color x:Key="Gray900">#212121</Color>
    <Color x:Key="Gray950">#141414</Color>

    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource Primary}"/>
    <SolidColorBrush x:Key="SecondaryBrush" Color="{StaticResource Secondary}"/>
    <SolidColorBrush x:Key="TertiaryBrush" Color="{StaticResource Tertiary}"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource Surface}"/>
    <SolidColorBrush x:Key="PageBackgroundBrush" Color="{StaticResource PageBackground}"/>
    <SolidColorBrush x:Key="WhiteBrush" Color="{StaticResource White}"/>
    <SolidColorBrush x:Key="BlackBrush" Color="{StaticResource Black}"/>

    <SolidColorBrush x:Key="Gray100Brush" Color="{StaticResource Gray100}"/>
    <SolidColorBrush x:Key="Gray200Brush" Color="{StaticResource Gray200}"/>
    <SolidColorBrush x:Key="Gray300Brush" Color="{StaticResource Gray300}"/>
    <SolidColorBrush x:Key="Gray400Brush" Color="{StaticResource Gray400}"/>
    <SolidColorBrush x:Key="Gray500Brush" Color="{StaticResource Gray500}"/>
    <SolidColorBrush x:Key="Gray600Brush" Color="{StaticResource Gray600}"/>
    <SolidColorBrush x:Key="Gray900Brush" Color="{StaticResource Gray900}"/>
    <SolidColorBrush x:Key="Gray950Brush" Color="{StaticResource Gray950}"/>
</ResourceDictionary>

<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:FoodVisionMauiDemo.Models"
             xmlns:viewModels="clr-namespace:FoodVisionMauiDemo.ViewModels"
             x:Class="FoodVisionMauiDemo.Views.InsightsPage"
             x:DataType="viewModels:InsightsViewModel"
             Title="Insights">
    <ScrollView>
        <VerticalStackLayout Padding="24,32,24,40" Spacing="20">
            <VerticalStackLayout Spacing="6">
                <Label Text="7-day balance"
                       Style="{StaticResource EyebrowLabel}" />
                <Label Text="Insights"
                       Style="{StaticResource Headline}"
                       SemanticProperties.HeadingLevel="Level1" />
                <Label Text="A simple dietary balance indicator from your saved meals. Not medical advice."
                       Style="{StaticResource BodyMutedLabel}" />
            </VerticalStackLayout>

            <Label Text="{Binding StatusMessage}"
                   Style="{StaticResource MutedLabel}" />

            <Border Style="{StaticResource TintCardFrame}">
                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                    <Border StrokeThickness="0"
                            StrokeShape="RoundRectangle 14"
                            WidthRequest="40"
                            HeightRequest="40"
                            BackgroundColor="{AppThemeBinding Light=#D1FAE5, Dark=#123D34}">
                        <Label Text="S"
                               FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                               HorizontalTextAlignment="Center"
                               VerticalTextAlignment="Center" />
                    </Border>
                    <Grid Grid.Column="1"
                          ColumnDefinitions="*,Auto"
                          ColumnSpacing="10">
                        <VerticalStackLayout Spacing="3">
                            <Label Text="Shake refresh"
                                   Style="{StaticResource EyebrowLabel}" />
                            <Label Text="{Binding ShakeStatusMessage}"
                                   Style="{StaticResource MutedLabel}"
                                   LineBreakMode="WordWrap" />
                        </VerticalStackLayout>
                        <Border Grid.Column="1"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 14"
                                Padding="10,6"
                                BackgroundColor="{AppThemeBinding Light=#ECFDF5, Dark=#123D34}"
                                VerticalOptions="Start">
                            <Label Text="{Binding ShakeRefreshCount}"
                                   FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                                   SemanticProperties.Description="Detected shake refresh count." />
                        </Border>
                    </Grid>
                </Grid>
            </Border>

            <ActivityIndicator IsVisible="{Binding IsBusy}"
                               IsRunning="{Binding IsBusy}"
                               HorizontalOptions="Center" />

            <Border Style="{StaticResource CardFrame}"
                    IsVisible="{Binding HasNoData}">
                <VerticalStackLayout Spacing="12"
                                     HorizontalOptions="Center">
                    <Border StrokeThickness="0"
                            StrokeShape="RoundRectangle 32"
                            BackgroundColor="{AppThemeBinding Light=#ECFDF5, Dark=#123D34}"
                            WidthRequest="64"
                            HeightRequest="64"
                            HorizontalOptions="Center">
                        <Label Text="+"
                               Style="{StaticResource EmptyStateMark}" />
                    </Border>
                    <Label Text="Not enough meal data yet"
                           Style="{StaticResource SubHeadline}"
                           HorizontalTextAlignment="Center" />
                    <Label Text="There is not enough meal data yet. Add more meals to see trends."
                           Style="{StaticResource BodyMutedLabel}"
                           HorizontalTextAlignment="Center" />
                    <Button Text="Scan your first food"
                            ImageSource="icon_scan_white.svg"
                            ContentLayout="Left,10"
                            Style="{StaticResource PrimaryButton}"
                            Clicked="OnScanFirstFoodClicked"
                            HorizontalOptions="Center"
                            SemanticProperties.Description="Open the scan page to add meal data for insights." />
                </VerticalStackLayout>
            </Border>

            <VerticalStackLayout Spacing="16"
                                 IsVisible="{Binding HasData}">
                <Border Style="{StaticResource HeroCard}"
                        SemanticProperties.Description="Today dietary balance indicator card with text risk level and color.">
                    <Grid RowDefinitions="Auto,Auto,Auto" ColumnDefinitions="*,Auto" RowSpacing="12">
                        <Label Text="Today's risk"
                               Style="{StaticResource SubHeadline}"
                               TextColor="{StaticResource White}" />
                        <Label Grid.Column="1"
                               Text="Indicator"
                               FontSize="{DynamicResource SmallFontSize}"
                               TextColor="#A7F3D0"
                               VerticalOptions="Center" />
                        <Label Grid.Row="1"
                               Grid.ColumnSpan="2"
                               Text="{Binding TodayRiskLevel}"
                               Style="{StaticResource MetricLabel}"
                               FontSize="44"
                               TextColor="{StaticResource White}"
                               SemanticProperties.Description="Today dietary risk level shown as text." />
                        <Grid Grid.Row="2" Grid.ColumnSpan="2" ColumnDefinitions="*,*" ColumnSpacing="12">
                            <Border StrokeThickness="0"
                                    StrokeShape="RoundRectangle 18"
                                    Padding="14"
                                    BackgroundColor="#1A514A">
                                <VerticalStackLayout Spacing="3">
                                    <Label Text="Score"
                                           TextColor="#A7F3D0"
                                           FontSize="{DynamicResource SmallFontSize}" />
                                    <Label Text="{Binding NormalizedRiskScoreText}"
                                           FontAttributes="Bold"
                                           TextColor="{StaticResource White}" />
                                </VerticalStackLayout>
                            </Border>
                            <Border Grid.Column="1"
                                    StrokeThickness="0"
                                    StrokeShape="RoundRectangle 18"
                                    Padding="14"
                                    BackgroundColor="#1A514A">
                                <VerticalStackLayout Spacing="3">
                                    <Label Text="Meaning"
                                           TextColor="#A7F3D0"
                                           FontSize="{DynamicResource SmallFontSize}" />
                                    <Label Text="Balance cue"
                                           FontAttributes="Bold"
                                           TextColor="{StaticResource White}" />
                                </VerticalStackLayout>
                            </Border>
                        </Grid>
                    </Grid>
                </Border>

                <Border Style="{StaticResource WarningFrame}"
                       IsVisible="{Binding HasLimitedData}">
                    <Label Text="{Binding DataMessage}"
                           Style="{StaticResource MutedLabel}"
                           TextColor="{AppThemeBinding Light={StaticResource Warning}, Dark={StaticResource WarningSoft}}" />
                </Border>

                <Border Style="{StaticResource CardFrame}">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="Last 7 days risk scores"
                               Style="{StaticResource SubHeadline}" />
                        <CollectionView ItemsSource="{Binding WeeklyScores}">
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="models:RiskTagScore">
                                    <Border Style="{StaticResource ListItemBorder}">
                                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                                            <Border StrokeThickness="0"
                                                    StrokeShape="RoundRectangle 12"
                                                    WidthRequest="28"
                                                    HeightRequest="28"
                                                    BackgroundColor="{AppThemeBinding Light=#D1FAE5, Dark=#123D34}"
                                                    VerticalOptions="Center">
                                                <Label Text="{Binding ShortLabel}"
                                                       FontAttributes="Bold"
                                                       TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                                                       HorizontalTextAlignment="Center"
                                                       VerticalTextAlignment="Center" />
                                            </Border>
                                            <Label Text="{Binding DisplayName}"
                                                   Grid.Column="1"
                                                   FontAttributes="Bold" />
                                            <Label Grid.Column="2"
                                                   Text="{Binding ScoreWithTrendText}"
                                                   FontAttributes="Bold"
                                                   TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </VerticalStackLayout>
                </Border>

                <Border Style="{StaticResource CardFrame}">
                    <VerticalStackLayout Spacing="8">
                        <Label Text="Risk Reason"
                               Style="{StaticResource SubHeadline}" />
                        <Label Text="{Binding Reason}"
                               FontSize="{DynamicResource BodyFontSize}"
                               LineBreakMode="WordWrap" />
                        <Label Text="{Binding TrendSummary}"
                               FontSize="{DynamicResource BodyFontSize}"
                               LineBreakMode="WordWrap" />
                        <Label Text="{Binding DataMessage}"
                               Style="{StaticResource MutedLabel}" />
                        <Button Text="Read Risk Summary"
                                ImageSource="icon_speaker_teal.svg"
                                ContentLayout="Left,10"
                                Style="{StaticResource SecondaryButton}"
                                Command="{Binding ReadRiskSummaryCommand}"
                                SemanticProperties.Description="Read the current dietary risk summary aloud." />
                    </VerticalStackLayout>
                </Border>

                <Border Style="{StaticResource CardFrame}">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="Alternative Food Suggestions"
                               Style="{StaticResource SubHeadline}" />
                        <CollectionView ItemsSource="{Binding Recommendations}">
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="models:FoodRecommendation">
                                    <Border Style="{StaticResource ListItemBorder}">
                                    <VerticalStackLayout Spacing="4">
                                        <Label Text="{Binding Title}"
                                               FontAttributes="Bold" />
                                        <Label Text="{Binding Reason}"
                                               Style="{StaticResource MutedLabel}"
                                               LineBreakMode="WordWrap" />
                                    </VerticalStackLayout>
                                    </Border>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </VerticalStackLayout>
                </Border>

                <Button Text="Find Nearby Balanced Options"
                        ImageSource="icon_location_white.svg"
                        ContentLayout="Left,10"
                        Style="{StaticResource SuccessButton}"
                        Command="{Binding FindNearbyCommand}"
                        SemanticProperties.Description="Find nearby food places using live location and AMap service." />
            </VerticalStackLayout>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
